# ============================================
# UNVEILS.ME — Complete Environment Variables
# ============================================

NEXT_PUBLIC_APP_URL=https://unveils.me
NEXT_PUBLIC_APP_DOMAIN=unveils.me
NODE_ENV=production

# Groq — FREE at console.groq.com
GROQ_API_KEY=gsk_xxxx

# Supabase — supabase.com (free tier)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres

# Upstash Redis — upstash.com (free 10k/day)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx

# Stripe — stripe.com (use sk_test_ for dev)
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_MONTHLY=price_xxxx
STRIPE_PRO_YEARLY=price_xxxx
STRIPE_ENT_MONTHLY=price_xxxx
STRIPE_ENT_YEARLY=price_xxxx

# Resend — resend.com (free 3k/month)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=Unveils.me <noreply@unveils.me>
RESEND_AUDIENCE_ID=aud_xxxx

# SEO & Analytics
GOOGLE_SITE_VERIFICATION=xxxx
BING_SITE_VERIFICATION=xxxx
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXX

# Security (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=your_32_char_random_secret_here

